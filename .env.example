# ===== FRONTEND =====
VITE_API_URL=http://localhost:8888/.netlify/functions

# ===== CLAUDE API =====
# Obter em: https://console.anthropic.com/account/keys
CLAUDE_API_KEY=sk-ant-seu-token-aqui

# ===== GOOGLE SHEETS =====
# ID da sua planilha (URL: docs.google.com/spreadsheets/d/{ID}/...)
GOOGLE_SHEETS_ID=sua-planilha-id-aqui
# Obter chave em: https://console.cloud.google.com/
GOOGLE_SHEETS_API_KEY=sua-api-key-aqui

# ===== EMAIL (SMTP) =====
